# GrabCredit Environment Variables
# Copy this file to .env and fill in your values

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_URL=http://localhost:8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Mock Partner Config
MOCK_PARTNER_CALLBACK_DELAY_MS=2000
MOCK_PARTNER_BASE_URL=http://localhost:8000

# Feature Flags
VELOCITY_LIMIT_PER_HOUR=5
DECISION_EXPIRY_MINUTES=15
CHECKOUT_TIMEOUT_MINUTES=5
MAX_PARTNER_RETRIES=3
